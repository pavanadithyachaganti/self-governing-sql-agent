  "guardrail_cases": [
    {"sql": "SELECT * FROM safety_incidents", "expect": "review", "note": "756 rows, no LIMIT -> large_result review"},
    {"sql": "SELECT * FROM safety_incidents LIMIT 20", "expect": "allow", "note": "bounded read"},
    {"sql": "SELECT severity, COUNT(*) FROM safety_incidents GROUP BY severity", "expect": "allow", "note": "aggregate"},
    {"sql": "DROP TABLE safety_incidents", "expect": "block:non_select", "note": "ddl"},
    {"sql": "DELETE FROM worker_vitals WHERE 1=1", "expect": "block:non_select", "note": "dml delete"},
    {"sql": "UPDATE operational_metrics SET productivity_index = 1", "expect": "block:non_select", "note": "dml update"},
    {"sql": "SELECT * FROM a; DROP TABLE b", "expect": "block:multiple_statements", "note": "stacked"},
    {"sql": "SELECT national_id FROM workers", "expect": "block:restricted_pii", "note": "raw pii"},
    {"sql": "SELECT full_name, monthly_salary_aed FROM workers", "expect": "block:restricted_pii", "note": "raw salary"},
    {"sql": "SELECT * FROM workers", "expect": "block:restricted_pii", "note": "star exposes pii"},
    {"sql": "SELECT w.* FROM workers w JOIN safety_incidents s ON w.worker_id = s.worker_id", "expect": "block:restricted_pii", "note": "alias star"},
    {"sql": "SELECT full_name FROM workers WHERE monthly_salary_aed > 30000", "expect": "block:restricted_pii", "note": "raw pii in where"},
    {"sql": "SELECT site_id, AVG(monthly_salary_aed) FROM workers GROUP BY site_id", "expect": "allow", "note": "aggregate over pii is allowed"},
    {"sql": "SELECT role, MAX(monthly_salary_aed), MIN(monthly_salary_aed) FROM workers GROUP BY role", "expect": "allow", "note": "min/max aggregate"},
    {"sql": "SELECT full_name, role, hire_date FROM workers", "expect": "allow", "note": "non-sensitive worker cols"},
    {"sql": "SELECT COUNT(*) FROM workers", "expect": "allow", "note": "count only"}
