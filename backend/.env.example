# ---- LLM provider: mock | anthropic | openai ----
# mock needs no key and runs the full pipeline with keyword-matched SQL.
LLM_PROVIDER=mock

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Guardrails (enforced starting week 2, read from config now) ----
MAX_RESULT_ROWS=200
MAX_JOIN_TABLES=2

# ---- Memory ----
MEMORY_SUMMARIZE_AFTER_TURNS=20

# ---- CORS ----
ALLOWED_ORIGINS=*
