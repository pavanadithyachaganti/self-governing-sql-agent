# ---- LLM provider: mock | anthropic | openai ----
# mock needs no key and runs the full pipeline with keyword-matched SQL.
LLM_PROVIDER=mock

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Guardrails ----
MAX_RESULT_ROWS=200      # a query estimated to return more rows (and with no LIMIT) needs human review
MAX_JOINS=2              # a query with more JOINs than this needs human review

# ---- Orchestration ----
MAX_REPAIRS=1            # auto-retries after a SQL execution error (feed the error back to the model)

# ---- Memory ----
MEMORY_SUMMARIZE_AFTER_TURNS=20

# ---- CORS ----
ALLOWED_ORIGINS=*
